# Gemini API key (free): https://ai.google.dev/ -> "Get API key"
GEMINI_API_KEY=your_gemini_api_key_here

# Your name / signature, used so replies sound like YOU
YOUR_NAME=Your Full Name
YOUR_ROLE=Data Science Intern
YOUR_SIGNATURE_BLOCK=Best regards,\nYour Full Name\nData Science Intern

# How many unread emails to process per run
MAX_EMAILS_PER_RUN=10
